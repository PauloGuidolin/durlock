---
// src/pages/index.astro
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Gallery from '../components/Gallery.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import WhatsAppOrb from '../components/WhatsAppOrb.astro';
import "../styles/global.css";

import Testimonials from '../components/Testimonials.astro';
// Datos para el Marquee (Cinta de correr)
const tags = [
  "PRESUPUESTOS SIN CARGO",
  "NIVEL 5 FINISH",
  "CONSTRUCCIÓN EN SECO",
  "GARANTÍA ESCRITA",
  "MAESTROS DEL DURLOCK",
  "AISLACIÓN ACÚSTICA",
];
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>STUDIO DURLOCK | Arquitectura en Seco Premium</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700;900&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-white font-['Space_Grotesk'] antialiased text-zinc-900 selection:bg-amber-500 selection:text-white">
    
    <WhatsAppOrb />

    <Header />
    
    <main>
      <Hero />

      <section class="bg-amber-500 py-6 border-y-2 border-zinc-900 overflow-hidden relative z-20">
        <div class="flex whitespace-nowrap animate-marquee">
          {Array(4).fill(0).map(() => (
            <div class="flex gap-12 items-center mx-6">
              {tags.map((tag) => (
                <span class="text-zinc-900 font-black text-xl md:text-2xl uppercase tracking-tighter flex items-center gap-4">
                  <span class="w-3 h-3 bg-zinc-900 rotate-45"></span>
                  {tag}
                </span>
              ))}
            </div>
          ))}
        </div>
      </section>

      <About />

      <Services />

      <div class="py-10 bg-zinc-900">
          <div class="container mx-auto px-6">
              <h2 class="text-white text-4xl font-black mb-12">PORTAFOLIO <span class="text-amber-500">REAL.</span></h2>
          </div>
          <Gallery />
      </div>

     <Testimonials/>

      <Contact />
    </main>

    <Footer />

    <style is:global>
      /* Animación del Marquee */
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .animate-marquee {
        display: flex;
        width: max-content;
        animation: marquee 40s linear infinite;
      }
      .animate-marquee:hover {
        animation-play-state: paused;
      }

      /* Estética de scrollbar personalizada */
      ::-webkit-scrollbar {
        width: 10px;
      }
      ::-webkit-scrollbar-track {
        background: #f1f1f1;
      }
      ::-webkit-scrollbar-thumb {
        background: #18181b;
        border-radius: 5px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #f59e0b;
      }

      /* Evitar desbordamiento horizontal */
      body, html {
        max-width: 100vw;
        overflow-x: hidden;
      }
    </style>

    <script>
      // Script opcional: Vibración del botón de WhatsApp para llamar la atención
      const waButton = document.querySelector('.fixed.bottom-8.right-8');
      if (waButton) {
        setInterval(() => {
          waButton.classList.add('animate-bounce');
          setTimeout(() => waButton.classList.remove('animate-bounce'), 2000);
        }, 15000);
      }
    </script>
  </body>
</html>
