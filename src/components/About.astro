---
// src/components/About.astro
---
<section id="nosotros" class="py-24 bg-zinc-50 border-y border-zinc-200">
  <div class="container mx-auto px-6 grid md:grid-cols-12 gap-8 items-center">
    <div class="md:col-span-5">
      <h2 class="text-4xl font-bold mb-6 text-zinc-900">ADN <span class="text-amber-500 italic">Estructural</span></h2>
      <p class="text-zinc-600 mb-8 leading-relaxed italic">"Creemos que el detalle más pequeño es el que sostiene toda la estructura."</p>
      <div class="grid grid-cols-2 gap-6">
        <div>
          <h4 class="font-black text-3xl text-zinc-900">120+</h4>
          <p class="text-xs text-zinc-400 uppercase tracking-widest font-bold">Obras Entregadas</p>
        </div>
        <div>
          <h4 class="font-black text-3xl text-zinc-900">0.0mm</h4>
          <p class="text-xs text-zinc-400 uppercase tracking-widest font-bold">Margen de Error</p>
        </div>
      </div>
    </div>
    <div class="md:col-span-7 h-80 bg-zinc-900 rounded-2xl relative overflow-hidden group">
        <div class="absolute inset-0 opacity-30 bg-[linear-gradient(rgba(255,255,255,.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.05)_1px,transparent_1px)] bg-[size:30px_30px]"></div>
        <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-white/20 text-9xl font-black">DRYKON</span>
        </div>
    </div>
  </div>
</section>