---
// src/components/Testimonials.astro
const reviews = [
  {
    name: "Arq. Valeria Santoro",
    role: "Directora en Studio V",
    text: "Lo que más valoro es la interpretación de los planos. Hicieron una garganta de luz curva que otros instaladores daban por imposible. El acabado Nivel 5 es real.",
    project: "Penthouse Puerto Madero",
    highlight: "Precisión Técnica"
  },
  {
    name: "Juan Ignacio López",
    role: "Dueño de 'The Coffee House'",
    text: "Necesitaba insonorizar el local sin perder estética. El sistema de doble placa con lana de roca que instalaron cambió el clima del lugar. Impecables y limpios.",
    project: "Local Comercial",
    highlight: "Aislación Acústica"
  },
  {
    name: "Dra. Elena Martínez",
    role: "Particular",
    text: "Hicieron toda mi casa en 10 días. Lo que más me sorprendió fue la limpieza; al final de cada jornada el lugar quedaba transitable. Un equipo de profesionales.",
    project: "Vivienda Unifamiliar",
    highlight: "Rapidez y Limpieza"
  },
  {
    name: "Marcos Reinoso",
    role: "Desarrollador Inmobiliario",
    text: "Trabajamos con ellos en 12 unidades funcionales simultáneas. No fallaron en una sola entrega. Son mi opción número uno para construcción en seco.",
    project: "Edificio Residencial",
    highlight: "Escalabilidad"
  }
];
---

<section class="py-24 bg-zinc-50 overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div>
        <h2 class="text-amber-500 font-bold tracking-[0.2em] uppercase text-sm mb-2">Social Proof</h2>
        <h3 class="text-5xl font-black text-zinc-900 tracking-tighter">VOCES DE <br/> <span class="text-zinc-400">CONFIANZA.</span></h3>
      </div>
      <div class="flex gap-2">
        <div class="px-4 py-2 bg-white border border-zinc-200 rounded-full text-xs font-bold shadow-sm">
            ⭐ 4.9/5 en Google Reviews
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {reviews.map((r) => (
        <div class="bg-white p-8 rounded-[2rem] border border-zinc-100 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-500 group">
          <div class="flex flex-col h-full">
            <span class="inline-block px-3 py-1 bg-zinc-900 text-white text-[10px] font-bold uppercase tracking-widest rounded-full w-fit mb-6 group-hover:bg-amber-500 transition-colors">
              {r.highlight}
            </span>
            
            <p class="text-zinc-600 leading-relaxed mb-8 flex-grow italic">
              "{r.text}"
            </p>
            
            <div class="border-t border-zinc-50 pt-6">
              <p class="font-bold text-zinc-900 text-lg">{r.name}</p>
              <p class="text-zinc-400 text-xs font-medium">{r.role}</p>
              <div class="mt-4 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-tighter">Obra: {r.project}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 bg-zinc-900 rounded-[3rem] p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-amber-500/20 blur-[80px]"></div>
        <div class="relative z-10 text-center md:text-left">
            <h4 class="text-2xl md:text-3xl font-bold text-white tracking-tight">¿Quieres ser nuestra próxima <span class="text-amber-500">historia de éxito?</span></h4>
            <p class="text-zinc-400 mt-2">Hablemos por WhatsApp y diseñemos tu espacio.</p>
        </div>
        <a href="https://wa.me/..." class="relative z-10 bg-white text-zinc-900 px-10 py-4 rounded-2xl font-black hover:bg-amber-500 hover:text-white transition-all transform active:scale-95 shadow-2xl">
            QUIERO MI PRESUPUESTO
        </a>
    </div>
  </div>
</section>