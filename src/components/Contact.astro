---
// src/components/Contact.astro
---
<section id="contacto" class="py-24 relative bg-white">
  <div class="container mx-auto px-6 grid md:grid-cols-2 gap-12 relative z-10">
    <div class="bg-zinc-900 p-10 md:p-16 rounded-[40px] text-white shadow-2xl">
      <h2 class="text-4xl font-bold mb-8 italic">¿Cotizamos <br/> tu idea?</h2>
      <form class="space-y-8">
        <div class="group relative">
            <input type="text" class="w-full bg-transparent border-b border-zinc-700 py-2 focus:outline-none focus:border-amber-500 transition-colors" placeholder="Nombre completo" />
        </div>
        <div class="group relative">
            <input type="email" class="w-full bg-transparent border-b border-zinc-700 py-2 focus:outline-none focus:border-amber-500 transition-colors" placeholder="Email de contacto" />
        </div>
        <button class="w-full py-4 bg-amber-500 text-zinc-900 font-black uppercase tracking-[0.2em] rounded-full hover:bg-white transition-colors duration-500">Enviar Solicitud</button>
      </form>
    </div>
    <div class="rounded-[40px] overflow-hidden grayscale border border-zinc-200 h-[500px]">
       <iframe src="https://www.google.com/maps/embed?..." class="w-full h-full object-cover"></iframe>
    </div>
  </div>
</section>