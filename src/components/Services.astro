---
// src/components/Services.astro
const services = [
  {
    title: "Cielorrasos Galaxia",
    desc: "Sistemas suspendidos con iluminación perimetral oculta y diseño de gargantas.",
    tag: "Iluminación",
    icon: "M5 3v18M19 3v18M5 12h14"
  },
  {
    title: "Tabiquería Curva",
    desc: "Desafiamos la línea recta con muros orgánicos que fluyen con el espacio.",
    tag: "Diseño",
    icon: "M4 4c0 16 16 16 16 0"
  },
  {
    title: "Aislación Acústica",
    desc: "Paz absoluta mediante sistemas de doble placa y lana de roca de alta densidad.",
    tag: "Ingeniería",
    icon: "M15.5 8.5L12 12l3.5 3.5M9 19h6a2 2 0 002-2V7a2 2 0 00-2-2H9a2 2 0 00-2 2v10a2 2 0 002 2z"
  }
];
---
<section id="servicios" class="py-32 bg-zinc-900 text-white relative overflow-hidden">
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-amber-500/10 blur-[120px] rounded-full"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl mb-20">
      <h2 class="text-amber-500 font-bold tracking-[0.3em] uppercase mb-4 text-sm">Expertise Técnico</h2>
      <h3 class="text-5xl md:text-6xl font-black tracking-tight leading-none">
        SOLUCIONES QUE <span class="text-zinc-600 italic">CONSTRUYEN</span> FUTURO.
      </h3>
    </div>

    <div class="grid md:grid-cols-3 gap-1px bg-zinc-800 border border-zinc-800">
      {services.map((s) => (
        <div class="bg-zinc-900 p-12 hover:bg-zinc-800/50 transition-all duration-500 group relative overflow-hidden">
          <div class="mb-8 p-3 w-fit rounded-lg bg-zinc-800 text-amber-500 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={s.icon} />
            </svg>
          </div>
          
          <span class="text-xs font-bold text-amber-500/50 uppercase tracking-widest">{s.tag}</span>
          <h4 class="text-2xl font-bold mt-2 mb-4 group-hover:text-amber-500 transition-colors">{s.title}</h4>
          <p class="text-zinc-400 leading-relaxed mb-8">
            {s.desc}
          </p>
          
          <a href="https://wa.me/..." class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-tighter group-hover:gap-4 transition-all">
            Consultar Ahora <span class="text-amber-500">→</span>
          </a>

          <div class="absolute -right-4 -bottom-4 w-24 h-24 border-r-2 border-b-2 border-amber-500/20 group-hover:border-amber-500 transition-colors"></div>
        </div>
      ))}
    </div>
    
    <div class="mt-20 flex flex-col md:flex-row items-center justify-between gap-8 border-t border-zinc-800 pt-12">
        <p class="text-zinc-500 max-w-sm">¿Buscas algo más complejo? Realizamos amoblamientos integrales y mobiliario fijo en Durlock.</p>
        <button class="bg-amber-500 text-zinc-900 px-10 py-4 rounded-full font-black hover:shadow-[0_0_30px_rgba(245,158,11,0.4)] transition-all">
            DESCARGAR CATÁLOGO TÉCNICO
        </button>
    </div>
  </div>
</section>