---
// Definimos los servicios para que sea fácil editarlos luego
const services = [
  {
    title: "Cielorrasos",
    description: "Juntas invisibles, perfectos para iluminación LED y aislación térmica.",
    icon: "🏠" 
  },
  {
    title: "Tabiquería",
    description: "Divisiones rápidas y acústicas para oficinas o nuevos ambientes.",
    icon: "🧱"
  },
  {
    title: "Revestimientos",
    description: "Soluciones definitivas para paredes con humedad y terminaciones finas.",
    icon: "✨"
  },
  {
    title: "Muebles a Medida",
    description: "Bibliotecas, racks de TV y nichos decorativos integrados.",
    icon: "🛠️"
  }
];
---

<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Nuestros Servicios</h2>
      <p class="text-gray-500 max-w-xl mx-auto">Soluciones en construcción en seco con materiales de primera línea y mano de obra especializada.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service) => (
        <div class="p-8 border border-gray-100 rounded-2xl bg-gray-50 hover:bg-white hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="text-4xl mb-4">{service.icon}</div>
          <h3 class="text-xl font-bold text-slate-800 mb-2">{service.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>