---
// src/components/Header.astro
---
<header class="fixed top-6 left-1/2 -translate-x-1/2 w-[90%] max-w-6xl z-50">
  <nav class="bg-white/70 backdrop-blur-xl border border-white/20 shadow-2xl rounded-2xl px-8 py-4 flex justify-between items-center">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 bg-amber-500 rounded-lg rotate-45 flex items-center justify-center shadow-lg">
        <span class="text-white font-bold -rotate-45">D</span>
      </div>
      <span class="text-xl font-black tracking-tighter text-zinc-900">STUDIO<span class="text-amber-500">DURLOCK</span></span>
    </div>
    <ul class="hidden md:flex gap-10 text-xs font-bold uppercase tracking-widest text-zinc-500">
      <li><a href="#proyectos" class="hover:text-amber-600 transition">Proyectos</a></li>
      <li><a href="#nosotros" class="hover:text-amber-600 transition">ADN</a></li>
      <li><a href="#servicios" class="hover:text-amber-600 transition">Servicios</a></li>
    </ul>
    <a href="#contacto" class="bg-zinc-900 text-white px-5 py-2 rounded-xl text-xs font-bold hover:scale-105 transition-transform active:scale-95">CONTACTO</a>
  </nav>
</header>