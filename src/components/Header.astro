<header class="fixed top-0 left-0 w-full bg-white/90 backdrop-blur-md z-50 border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 bg-yellow-400 rounded-lg flex items-center justify-center font-black text-slate-900">
        D
      </div>
      <span class="text-xl font-bold tracking-tight text-slate-900">
        Durlock<span class="text-yellow-500">Pro</span>
      </span>
    </div>

    <nav class="hidden md:flex items-center gap-8">
      <a href="#inicio" class="text-sm font-semibold text-slate-600 hover:text-yellow-500 transition-colors">Inicio</a>
      <a href="#servicios" class="text-sm font-semibold text-slate-600 hover:text-yellow-500 transition-colors">Servicios</a>
      <a href="#nosotros" class="text-sm font-semibold text-slate-600 hover:text-yellow-500 transition-colors">Nosotros</a>
      <a href="#contacto" class="text-sm font-semibold text-slate-600 hover:text-yellow-500 transition-colors">Contacto</a>
      
      <a 
        href="#contacto" 
        class="bg-slate-900 text-white px-5 py-2.5 rounded-full text-sm font-bold hover:bg-slate-700 transition-all shadow-lg shadow-slate-200"
      >
        Pedir Presupuesto
      </a>
    </nav>

    <button class="md:hidden p-2 text-slate-900" aria-label="Abrir menú">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
